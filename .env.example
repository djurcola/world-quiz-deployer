# Example environment variables for World Quiz deployment
# Copy this file to .env and customize for your environment

# SpacetimeDB WebSocket URI
# For local deployment: ws://localhost:3080
# For production with TLS: wss://spacetime.yourdomain.com
VITE_SPACETIME_URI=ws://localhost:3080

# SpacetimeDB database name
VITE_DB_NAME=world-quiz
